# .env.local — Copy this to your local project root
# Also add these to Vercel Dashboard → Settings → Environment Variables

# Your deployed Google Apps Script Web App URL
# Get this from: Extensions → Apps Script → Deploy → Manage Deployments → Web App URL
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Secret key — must match API_SECRET in Code.gs
NEXT_PUBLIC_GAS_SECRET=your-secret-key-here
